<div class="hero-section">
  <div class="hero-content">
    <h1>Nouvelle Collection 2026</h1>
    <p>Découvrez nos produits tech dernière génération avec des réductions exclusives.</p>
    <a href="#shop" class="btn btn-large">Voir les offres</a>
  </div>
</div>

<div class="shop-container" id="shop">
  <aside class="sidebar">
    <h3>Catégories</h3>
    <ul class="category-list">
      <li class="active"><a href="/">Toutes les catégories</a></li>
      <li><a href="/?cat=1">Ordinateurs & Laptops</a></li>
      <li><a href="/?cat=2">Smartphones</a></li>
      <li><a href="/?cat=3">Audio & Casques</a></li>
      <li><a href="/?cat=4">Accessoires</a></li>
    </ul>

    <h3 style="margin-top: 2rem;">Filtres</h3>
    <div class="filter-group">
      <label><input type="checkbox"> En promotion</label>
      <label><input type="checkbox"> En stock uniquement</label>
    </div>
  </aside>

  <section class="products-section">
    <div class="section-header">
      <h2>Nos Produits Tendance</h2>
      <div class="sort-by">
        <select>
          <option>Trier par : Nouveautés</option>
          <option>Prix croissant</option>
          <option>Prix décroissant</option>
        </select>
      </div>
    </div>
    
    <div class="products-grid">
      <% if (products && products.length > 0) { %>
        <% products.forEach(p => { %>
          <div class="product-card">
            <div class="product-image-wrapper">
              <img src="<%= p.image_url || 'https://images.unsplash.com/photo-1505740420928-5e560c06d30e?w=500&q=80' %>" alt="<%= p.name %>" class="product-image">
              <% if (p.stock < 5) { %>
                <span class="badge badge-warning">Plus que <%= p.stock %> en stock</span>
              <% } %>
            </div>
            <div class="product-info">
              <div class="product-category"><%= p.category_name || 'Technologie' %></div>
              <div class="product-title"><%= p.name %></div>
              <div class="product-description"><%= p.description || 'Produit de haute qualité.' %></div>
              <div class="product-bottom">
                <div class="product-price"><%= p.price.toFixed(2) %> €</div>
                <a href="/cart/add/<%= p.id %>" class="btn btn-icon" title="Ajouter au panier">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
                </a>
              </div>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <div class="empty-state">
          <p>Aucun produit disponible pour le moment.</p>
        </div>
      <% } %>
    </div>
  </section>
</div>
